{
  "functions": {
    "api/XHTTP.js": {
      "memory": 128,
      "maxDuration": 60
    }
  },
  "rewrites":  [
    { "source": "/freedom:path*", "destination": "/api/XHTTP" },
    { "source": "/freedom", "destination": "/api/XHTTP" },
    {"source": "/(.*)", "destination": "/index.html"}
  ],
  "trailingSlash": false
}
